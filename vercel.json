{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.mach-t.app" }], "destination": "https://mach-t.app/$1", "permanent": true },
    { "source": "/ios", "destination": "https://apps.apple.com/app/id6766287371", "permanent": false },
    { "source": "/app-store", "destination": "https://apps.apple.com/app/id6766287371", "permanent": false },
    { "source": "/play", "destination": "https://play.google.com/store/apps/details?id=com.eseate.macht", "permanent": false },
    { "source": "/app", "destination": "https://mach-t.app/#download", "permanent": false },
    { "source": "/descarga", "destination": "https://mach-t.app/#download", "permanent": false }
  ]
}
